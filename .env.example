# ===== Core server =====
PORT=3000

# ===== SmartThings OAuth (required for production) =====
SMARTTHINGS_CLIENT_ID=
SMARTTHINGS_CLIENT_SECRET=
SMARTTHINGS_REDIRECT_URI=https://smarthost.nextfintechai.com/oauth/callback
SMARTTHINGS_DEFAULT_DEVICE_ID=

# ===== MongoDB Atlas (required for multi-host) =====
# Example:
# mongodb+srv://admin:password@cluster0.xxxxx.mongodb.net/onyx?retryWrites=true&w=majority&appName=Cluster0
MONGO_URI=

# ===== Scheduler =====
RUN_MONGO_AUTOMATION=true

# ===== Existing bridge/mock flags =====
OAUTH_MOCK_MODE=false
MOCK_AGENT_ID=r1
BRIDGE_TOKEN=
